# ===========================================
# Daret Backoffice — Environment variables
# Copy to .env and set values. Only VITE_* are exposed to the client.
# ===========================================

# --- API (required) ---
# Backend base URL. API requests go to ${VITE_API_URL}/api/admin
VITE_API_URL=http://localhost:3000

# --- App (optional) ---
# Display name for the backoffice (e.g. in title or header)
VITE_APP_NAME=Daret Backoffice

# Optional: label in profile menu — local | staging | production (overrides dev/prod inference)
# VITE_BACKOFFICE_ENV=staging
